---
import "../styles/input.css";
import StructuredData from "../components/StructuredData.astro";

interface Props {
  title?: string;
  description?: string;
  type?: "website" | "article";
  date?: string;
}

const {
  title = "Leica Oracle — Blog",
  description = "บันทึกเทคนิค เครื่องมือ และบทเรียนจาก Leica Oracle",
  type = "website",
  date,
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : Astro.url.pathname;
---

<!doctype html>
<html lang="th">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content={type === "article" ? "article" : "website"} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Leica Oracle" />
    <meta property="og:locale" content="th_TH" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <StructuredData type={type} title={title} description={description} url={canonical} date={date} />
    <link rel="stylesheet" href={`${base}/fonts.css`} />
  </head>
  <body>
    <slot />
  </body>
</html>
